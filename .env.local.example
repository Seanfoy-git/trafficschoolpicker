# Site
NEXT_PUBLIC_SITE_URL=https://trafficschoolpicker.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Notion — internal integration token from https://www.notion.so/my-integrations
# The integration must be "connected" to each database page in Notion
# (Share > Invite > select your integration)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SCHOOLS_DB=              # Traffic Schools DB (Tier 1/2 curated schools)
NOTION_DIRECTORY_DB=            # School Directory DB (DMV-scraped schools)
NOTION_STATES_DB=               # States DB (online status per state)
NOTION_PRICING_DB=              # School Pricing DB (school × state price rows)
NOTION_FAQ_DB_ID=               # State FAQs DB (per-state FAQ content)

# Vercel deploy hook — create at Vercel > Project > Settings > Git > Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# Google Places API — for enriching directory schools with websites
# Get a key at console.cloud.google.com, enable "Places API (New)"
GOOGLE_PLACES_API_KEY=
